rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Onboarding Profiles ──────────────────────────────────────────────────
    match /onboardingProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Exercises (read-only for all auth users) ─────────────────────────────
    match /exercises/{exerciseId} {
      allow read: if isAuth();
      allow write: if false; // admin only via Firebase console / seed scripts
    }

    // ── Workout Templates (read-only for all auth users) ─────────────────────
    match /workoutTemplates/{templateId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── Custom Workouts ───────────────────────────────────────────────────────
    match /customWorkouts/{workoutId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Workout Sessions ──────────────────────────────────────────────────────
    match /workoutSessions/{sessionId} {
      allow read, create: if isAuth() && (
        resource == null
          ? request.resource.data.userId == request.auth.uid
          : resource.data.userId == request.auth.uid
      );
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Progress Photos ───────────────────────────────────────────────────────
    match /progressPhotos/{photoId} {
      allow read, write: if isAuth() && (
        resource == null
          ? request.resource.data.userId == request.auth.uid
          : resource.data.userId == request.auth.uid
      );
    }

    // ── Personal Records ──────────────────────────────────────────────────────
    match /personalRecords/{recordId} {
      allow read, write: if isAuth() && (
        resource == null
          ? request.resource.data.userId == request.auth.uid
          : resource.data.userId == request.auth.uid
      );
    }

    // ── Milestones ────────────────────────────────────────────────────────────
    match /milestones/{milestoneId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if false; // system-generated only
    }

    // ── Gym Challenges (public read) ──────────────────────────────────────────
    match /gymChallenges/{challengeId} {
      allow read: if isAuth();
      allow write: if false;
    }
  }
}
